# --- SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=development

# --- DATABASE ---
# Format: mongodb://[username:password@]host[:port]/database
MONGO_URL=mongodb://localhost:27017/smartdokon_v41

# --- SECURITY & AUTH ---
# Secret keys for JWT signing. Generate strong random strings.
JWT_SECRET_KEY=your_very_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Cookie settings for auth
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- RATE LIMITING ---
# 15 minutes = 900000 ms
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30

# --- BUSINESS LOGIC ---
# OWNER_ID: Telegram Chat ID of the main owner
OWNER_ID=123456789
# SUBSCRIPTION: STANDARD or PRO (PRO enables Telegram bots)
SUBSCRIPTION=PRO
# Maximum number of branches allowed
MAX_BRANCH_LIMIT=5
# System-wide timezone
APP_TIMEZONE=Asia/Tashkent

# --- TELEGRAM BOTS ---
# These are used as defaults if not set in the database
BOT_TOKEN=
BOT_TOKEN_CLIENT=

# --- BACKUP SYSTEM ---
# Key for authorizing external backup devices
BACKUP_DEVICE_KEY=your_backup_device_key
# Enable automatic local backups via cron
LOCAL_BACKUP_ENABLED=true
# Path to store local backups
LOCAL_BACKUP_ROOT_DIR=C:\smartdokon
# Cron schedule for local backups (default: every 12 hours)
LOCAL_BACKUP_SCHEDULE=0 0,12 * * *
# Number of old backups to keep
LOCAL_BACKUP_RETENTION=14

# --- SMART AUTOPILOT & CRON ---
# Schedule for checking autopilot risks
AUTOPILOT_DANGER_SCHEDULE=*/30 * * * *
# Hours to wait before re-notifying about the same danger
AUTOPILOT_DANGER_DEDUPE_HOURS=12
# Primary timezone for cron jobs (fallback to APP_TIMEZONE)
CRON_TIMEZONE=Asia/Tashkent
